# -----------------------------------------------------------------------------
# GLOBAL / OS / IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# ENVIRONMENT VARIABLES (CRITICAL)
# -----------------------------------------------------------------------------
# We ignore the actual .env files which contain secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# We DO NOT ignore .env.example as it serves as a template for other devs
!.env.example

# -----------------------------------------------------------------------------
# BACKEND (Python / FastAPI)
# -----------------------------------------------------------------------------
# Cache and compiled files
**/__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual Environments
venv/
env/
.venv/
ENV/

# Database and Logs
*.db
*.sqlite3
db.sqlite3
*.log

# App specific
app/uploads/*
!app/uploads/.gitkeep

# -----------------------------------------------------------------------------
# FRONTEND (Node / React / Vite)
# -----------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
coverage/

# Log files
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
.dockerignore